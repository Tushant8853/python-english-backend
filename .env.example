# Server
PORT=3000
ENVIRONMENT=development

# MongoDB (Motor) — if URI has no database path, MONGODB_DB_NAME defaults to test (Mongoose behavior)
MONGODB_URI=mongodb+srv://user:pass@cluster.mongodb.net/english-guru
# MONGODB_DB_NAME=english-guru

# Firebase Admin — must match mobile google-services.json (learning-app-119d3)
FIREBASE_PROJECT_ID=learning-app-119d3
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@learning-app-119d3.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_PRIVATE_KEY\n-----END PRIVATE KEY-----\n"

# JWT
JWT_SECRET=replace-with-a-strong-secret
JWT_ACCESS_TOKEN_EXPIRY=365d

# Optional — comma-separated hosts for TrustedHostMiddleware in production
# ALLOWED_HOSTS=localhost,127.0.0.1
