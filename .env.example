# Server
PORT=3000
ENVIRONMENT=development

# MongoDB (Motor) — if URI has no database path, MONGODB_DB_NAME defaults to test (Mongoose behavior)
MONGODB_URI=mongodb+srv://user:pass@cluster.mongodb.net/english-guru
# MONGODB_DB_NAME=english-guru

# Firebase Admin — must match mobile google-services.json (learning-app-119d3)
FIREBASE_PROJECT_ID=learning-app-119d3
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@learning-app-119d3.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_PRIVATE_KEY\n-----END PRIVATE KEY-----\n"

# JWT
JWT_SECRET=replace-with-a-strong-secret
JWT_ACCESS_TOKEN_EXPIRY=365d

# Web admin dashboard (dashboard/ — separate from mobile JWT)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=replace-with-strong-password
ADMIN_JWT_SECRET=replace-with-admin-jwt-secret

# AWS S3 + CloudFront (intro/sales video uploads via web-admin)
AWS_ACCESS_KEY_ID=your-aws-access-key-id
AWS_SECRET_ACCESS_KEY=your-aws-secret-access-key
AWS_REGION=us-east-1
AWS_S3_BUCKET_NAME=learning-app-vids
CLOUDFRONT_DISTRIBUTION_DOMAIN=d1ta1qd8y4woyq.cloudfront.net
ASSET_BASE_URL=https://d1ta1qd8y4woyq.cloudfront.net

# Optional — comma-separated hosts for TrustedHostMiddleware in production
# ALLOWED_HOSTS=localhost,127.0.0.1
